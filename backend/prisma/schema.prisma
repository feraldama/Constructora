generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Usuarios del sistema
model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  avatarUrl      String?         @map("avatar_url")
  globalRole     GlobalRole      @default(USER) @map("global_role")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  activityLogs   ActivityLog[]
  notifications  Notification[]
  projectMembers ProjectMember[]

  @@map("users")
}

/// Proyectos de obra
model Project {
  id            String              @id @default(uuid())
  name          String
  description   String?
  address       String?
  initialBudget Decimal             @default(0) @map("initial_budget") @db.Decimal(14, 2)
  status        ProjectStatus       @default(PLANNING)
  startDate     DateTime?           @map("start_date")
  estimatedEnd  DateTime?           @map("estimated_end")
  actualEnd     DateTime?           @map("actual_end")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  activityLogs  ActivityLog[]
  attachments   Attachment[]
  budgetSummary BudgetSummary?
  categories    Category[]
  expenses      ProjectExpense[]
  payments      Payment[]
  contractors   ProjectContractor[]
  members       ProjectMember[]

  @@index([status, createdAt(sort: Desc)])
  @@map("projects")
}

/// Relación muchos-a-muchos entre usuarios y proyectos con rol
model ProjectMember {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  projectId String      @map("project_id")
  role      ProjectRole @default(VIEWER)
  joinedAt  DateTime    @default(now()) @map("joined_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_members")
}

/// Categorías / Rubros del cómputo métrico
model Category {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  name        String
  description String?
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  budgetItems BudgetItem[]
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
  @@map("categories")
}

/// Partidas / Items del cómputo métrico
model BudgetItem {
  id          String                 @id @default(uuid())
  categoryId  String                 @map("category_id")
  name        String
  description String?
  unit           MeasurementUnit
  quantity       Decimal                @default(0) @db.Decimal(12, 4)
  costUnitPrice  Decimal                @default(0) @map("cost_unit_price") @db.Decimal(14, 2)
  saleUnitPrice  Decimal                @default(0) @map("sale_unit_price") @db.Decimal(14, 2)
  costSubtotal   Decimal                @default(0) @map("cost_subtotal") @db.Decimal(14, 2)
  saleSubtotal   Decimal                @default(0) @map("sale_subtotal") @db.Decimal(14, 2)
  sortOrder      Int                    @default(0) @map("sort_order")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  attachments Attachment[]
  category    Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assignments ContractorAssignment[]
  payments    Payment[]

  @@index([categoryId, sortOrder])
  @@map("budget_items")
}

/// Contratistas
model Contractor {
  id          String                 @id @default(uuid())
  name        String
  contactName String?                @map("contact_name")
  email       String?
  phone       String?
  taxId       String?                @unique @map("tax_id")
  address     String?
  notes       String?
  isActive    Boolean                @default(true) @map("is_active")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  attachments Attachment[]
  assignments ContractorAssignment[]
  payments    Payment[]
  projects    ProjectContractor[]

  @@index([isActive, name])
  @@map("contractors")
}

/// Relación contratista-proyecto
model ProjectContractor {
  id           String     @id @default(uuid())
  projectId    String     @map("project_id")
  contractorId String     @map("contractor_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, contractorId])
  @@index([contractorId])
  @@map("project_contractors")
}

/// Asignación de partidas a contratistas
model ContractorAssignment {
  id               String     @id @default(uuid())
  contractorId     String     @map("contractor_id")
  budgetItemId     String     @map("budget_item_id")
  assignedQuantity Decimal    @default(0) @map("assigned_quantity") @db.Decimal(12, 4)
  agreedPrice      Decimal    @default(0) @map("agreed_price") @db.Decimal(14, 2)
  notes            String?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  budgetItem       BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  contractor       Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@unique([contractorId, budgetItemId])
  @@index([budgetItemId])
  @@map("contractor_assignments")
}

/// Pagos a contratistas
model Payment {
  id            String         @id @default(uuid())
  projectId     String         @map("project_id")
  contractorId  String         @map("contractor_id")
  budgetItemId  String?        @map("budget_item_id")
  amount        Decimal        @db.Decimal(14, 2)
  status        PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod? @map("payment_method")
  description   String?
  invoiceNumber String?        @map("invoice_number")
  dueDate       DateTime?      @map("due_date")
  paidAt        DateTime?      @map("paid_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  attachments   Attachment[]
  budgetItem    BudgetItem?   @relation(fields: [budgetItemId], references: [id])
  contractor    Contractor    @relation(fields: [contractorId], references: [id])
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([projectId, contractorId])
  @@index([status, dueDate])
  @@index([projectId, createdAt(sort: Desc)])
  @@map("payments")
}

/// Gastos adicionales del proyecto (no ligados a partidas)
model ProjectExpense {
  id          String      @id @default(uuid())
  projectId   String      @map("project_id")
  description String
  amount      Decimal     @db.Decimal(14, 2)
  expenseType ExpenseType @map("expense_type")
  expenseDate DateTime    @default(now()) @map("expense_date")
  invoiceRef  String?     @map("invoice_ref")
  notes       String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, expenseType])
  @@index([projectId, expenseDate(sort: Desc)])
  @@map("project_expenses")
}

/// Resumen de presupuesto por proyecto (tabla desnormalizada para dashboard rápido)
model BudgetSummary {
  id               String    @id @default(uuid())
  projectId        String    @unique @map("project_id")
  estimatedTotal   Decimal   @default(0) @map("estimated_total") @db.Decimal(14, 2)
  actualTotal      Decimal   @default(0) @map("actual_total") @db.Decimal(14, 2)
  totalPaid        Decimal   @default(0) @map("total_paid") @db.Decimal(14, 2)
  totalPending     Decimal   @default(0) @map("total_pending") @db.Decimal(14, 2)
  totalRevenue     Decimal   @default(0) @map("total_revenue") @db.Decimal(14, 2)
  totalCostItems   Decimal   @default(0) @map("total_cost_items") @db.Decimal(14, 2)
  totalExpenses    Decimal   @default(0) @map("total_expenses") @db.Decimal(14, 2)
  grossProfit      Decimal   @default(0) @map("gross_profit") @db.Decimal(14, 2)
  profitMargin     Decimal   @default(0) @map("profit_margin") @db.Decimal(5, 2)
  lastCalculatedAt DateTime? @map("last_calculated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("budget_summaries")
}

/// Archivos adjuntos relacionables a múltiples entidades
model Attachment {
  id           String           @id @default(uuid())
  fileName     String           @map("file_name")
  fileUrl      String           @map("file_url")
  fileSize     Int?             @map("file_size")
  mimeType     String?          @map("mime_type")
  entityType   AttachmentEntity @map("entity_type")
  projectId    String?          @map("project_id")
  budgetItemId String?          @map("budget_item_id")
  contractorId String?          @map("contractor_id")
  paymentId    String?          @map("payment_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  budgetItem   BudgetItem?      @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  contractor   Contractor?      @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  payment      Payment?         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([entityType, projectId])
  @@index([entityType, budgetItemId])
  @@index([entityType, contractorId])
  @@index([entityType, paymentId])
  @@map("attachments")
}

/// Notificaciones para usuarios
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

/// Registro de actividad para auditoría
model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  projectId  String?  @map("project_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([projectId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

enum GlobalRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum ProjectRole {
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum MeasurementUnit {
  M2
  M3
  ML
  UNIT
  KG
  TON
  GLOBAL
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AttachmentEntity {
  PROJECT
  BUDGET_ITEM
  CONTRACTOR
  PAYMENT
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_OVERDUE
  PROJECT_UPDATE
  ASSIGNMENT_CREATED
  GENERAL
}

enum ExpenseType {
  MATERIALS
  EQUIPMENT
  OVERHEAD
  PERMITS
  OTHER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  OTHER
}
