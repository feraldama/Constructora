generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Usuarios del sistema
model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  avatarUrl      String?         @map("avatar_url")
  globalRole     GlobalRole      @default(USER) @map("global_role")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  activityLogs    ActivityLog[]
  notifications   Notification[]
  projectMembers  ProjectMember[]
  progressEntries ProgressEntry[]

  @@map("users")
}

/// Proyectos de obra
model Project {
  id            String              @id @default(uuid())
  name          String
  description   String?
  address       String?
  initialBudget Decimal             @default(0) @map("initial_budget") @db.Decimal(14, 2)
  status        ProjectStatus       @default(PLANNING)
  startDate     DateTime?           @map("start_date")
  estimatedEnd  DateTime?           @map("estimated_end")
  actualEnd     DateTime?           @map("actual_end")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  activityLogs  ActivityLog[]
  attachments   Attachment[]
  budgetSummary BudgetSummary?
  categories    Category[]
  certificates  Certificate[]
  expenses      ProjectExpense[]
  payments      Payment[]
  contractors   ProjectContractor[]
  members        ProjectMember[]
  clientPayments ClientPayment[]

  @@index([status, createdAt(sort: Desc)])
  @@map("projects")
}

/// Relación muchos-a-muchos entre usuarios y proyectos con rol
model ProjectMember {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  projectId String      @map("project_id")
  role      ProjectRole @default(VIEWER)
  joinedAt  DateTime    @default(now()) @map("joined_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_members")
}

/// Categorías / Rubros del cómputo métrico
model Category {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  name        String
  description String?
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  budgetItems BudgetItem[]
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
  @@map("categories")
}

/// Partidas / Items del cómputo métrico
model BudgetItem {
  id          String                 @id @default(uuid())
  categoryId  String                 @map("category_id")
  name        String
  description String?
  unit           MeasurementUnit
  quantity       Decimal                @default(0) @db.Decimal(12, 4)
  costUnitPrice  Decimal                @default(0) @map("cost_unit_price") @db.Decimal(14, 2)
  saleUnitPrice  Decimal                @default(0) @map("sale_unit_price") @db.Decimal(14, 2)
  costSubtotal   Decimal                @default(0) @map("cost_subtotal") @db.Decimal(14, 2)
  saleSubtotal   Decimal                @default(0) @map("sale_subtotal") @db.Decimal(14, 2)
  sortOrder      Int                    @default(0) @map("sort_order")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  attachments      Attachment[]
  category         Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assignments      ContractorAssignment[]
  certificateItems CertificateItem[]
  expenses         ProjectExpense[]
  payments         Payment[]
  progressEntries  ProgressEntry[]
  apuMaterials     BudgetItemMaterial[]
  apuLabor         BudgetItemLabor[]

  @@index([categoryId, sortOrder])
  @@map("budget_items")
}

/// Contratistas
model Contractor {
  id          String                 @id @default(uuid())
  name        String
  contactName String?                @map("contact_name")
  email       String?
  phone       String?
  taxId       String?                @unique @map("tax_id")
  address     String?
  notes       String?
  isActive    Boolean                @default(true) @map("is_active")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  attachments  Attachment[]
  assignments  ContractorAssignment[]
  certificates Certificate[]
  payments     Payment[]
  projects     ProjectContractor[]

  @@index([isActive, name])
  @@map("contractors")
}

/// Relación contratista-proyecto
model ProjectContractor {
  id           String     @id @default(uuid())
  projectId    String     @map("project_id")
  contractorId String     @map("contractor_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, contractorId])
  @@index([contractorId])
  @@map("project_contractors")
}

/// Asignación de partidas a contratistas
model ContractorAssignment {
  id               String     @id @default(uuid())
  contractorId     String     @map("contractor_id")
  budgetItemId     String     @map("budget_item_id")
  assignedQuantity Decimal    @default(0) @map("assigned_quantity") @db.Decimal(12, 4)
  agreedPrice      Decimal    @default(0) @map("agreed_price") @db.Decimal(14, 2)
  notes            String?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  budgetItem       BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  contractor       Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@unique([contractorId, budgetItemId])
  @@index([budgetItemId])
  @@map("contractor_assignments")
}

/// Pagos a contratistas
model Payment {
  id            String         @id @default(uuid())
  projectId     String         @map("project_id")
  contractorId  String         @map("contractor_id")
  budgetItemId   String?         @map("budget_item_id")
  certificateId  String?         @map("certificate_id")
  amount         Decimal         @db.Decimal(14, 2)
  status         PaymentStatus   @default(PENDING)
  paymentMethod  PaymentMethod?  @map("payment_method")
  description    String?
  invoiceNumber  String?         @map("invoice_number")
  dueDate        DateTime?       @map("due_date")
  paidAt         DateTime?       @map("paid_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  attachments    Attachment[]
  budgetItem     BudgetItem?    @relation(fields: [budgetItemId], references: [id])
  certificate    Certificate?   @relation(fields: [certificateId], references: [id])
  contractor     Contractor     @relation(fields: [contractorId], references: [id])
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([projectId, contractorId])
  @@index([status, dueDate])
  @@index([projectId, createdAt(sort: Desc)])
  @@map("payments")
}

/// Gastos adicionales del proyecto
model ProjectExpense {
  id           String      @id @default(uuid())
  projectId    String      @map("project_id")
  description  String
  quantity     Decimal     @default(1) @db.Decimal(12, 4)
  unitPrice    Decimal     @default(0) @map("unit_price") @db.Decimal(14, 2)
  amount       Decimal     @db.Decimal(14, 2)
  expenseType  ExpenseType @map("expense_type")
  expenseDate  DateTime    @default(now()) @map("expense_date")
  invoiceRef   String?     @map("invoice_ref")
  notes        String?
  budgetItemId String?     @map("budget_item_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetItem BudgetItem? @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)

  @@index([projectId, expenseType])
  @@index([projectId, expenseDate(sort: Desc)])
  @@index([budgetItemId])
  @@map("project_expenses")
}

/// Resumen de presupuesto por proyecto (tabla desnormalizada para dashboard rápido)
model BudgetSummary {
  id               String    @id @default(uuid())
  projectId        String    @unique @map("project_id")
  estimatedTotal   Decimal   @default(0) @map("estimated_total") @db.Decimal(14, 2)
  actualTotal      Decimal   @default(0) @map("actual_total") @db.Decimal(14, 2)
  totalPaid        Decimal   @default(0) @map("total_paid") @db.Decimal(14, 2)
  totalPending     Decimal   @default(0) @map("total_pending") @db.Decimal(14, 2)
  totalRevenue     Decimal   @default(0) @map("total_revenue") @db.Decimal(14, 2)
  totalCostItems   Decimal   @default(0) @map("total_cost_items") @db.Decimal(14, 2)
  totalExpenses    Decimal   @default(0) @map("total_expenses") @db.Decimal(14, 2)
  grossProfit          Decimal   @default(0) @map("gross_profit") @db.Decimal(14, 2)
  profitMargin         Decimal   @default(0) @map("profit_margin") @db.Decimal(5, 2)
  totalClientPayments  Decimal   @default(0) @map("total_client_payments") @db.Decimal(14, 2)
  cashFlow             Decimal   @default(0) @map("cash_flow") @db.Decimal(14, 2)
  lastCalculatedAt     DateTime? @map("last_calculated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("budget_summaries")
}

/// Archivos adjuntos relacionables a múltiples entidades
model Attachment {
  id           String           @id @default(uuid())
  fileName     String           @map("file_name")
  fileUrl      String           @map("file_url")
  fileSize     Int?             @map("file_size")
  mimeType     String?          @map("mime_type")
  entityType   AttachmentEntity @map("entity_type")
  projectId    String?          @map("project_id")
  budgetItemId String?          @map("budget_item_id")
  contractorId String?          @map("contractor_id")
  paymentId    String?          @map("payment_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  budgetItem   BudgetItem?      @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  contractor   Contractor?      @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  payment      Payment?         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([entityType, projectId])
  @@index([entityType, budgetItemId])
  @@index([entityType, contractorId])
  @@index([entityType, paymentId])
  @@map("attachments")
}

/// Notificaciones para usuarios
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

/// Registro de actividad para auditoría
model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  projectId  String?  @map("project_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([projectId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

/// Certificación periódica de obra ejecutada por contratista
model Certificate {
  id                String            @id @default(uuid())
  projectId         String            @map("project_id")
  contractorId      String            @map("contractor_id")
  certificateNumber Int               @map("certificate_number")
  periodStart       DateTime          @map("period_start")
  periodEnd         DateTime          @map("period_end")
  status            CertificateStatus @default(DRAFT)
  notes             String?
  totalAmount       Decimal           @default(0) @map("total_amount") @db.Decimal(14, 2)
  submittedAt       DateTime?         @map("submitted_at")
  approvedAt        DateTime?         @map("approved_at")
  rejectedAt        DateTime?         @map("rejected_at")
  rejectionReason   String?           @map("rejection_reason")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractor Contractor        @relation(fields: [contractorId], references: [id])
  items      CertificateItem[]
  payments   Payment[]

  @@unique([projectId, certificateNumber])
  @@index([projectId, status])
  @@index([projectId, contractorId])
  @@map("certificates")
}

/// Línea de detalle de certificación (una por partida asignada)
model CertificateItem {
  id                  String     @id @default(uuid())
  certificateId       String     @map("certificate_id")
  budgetItemId        String     @map("budget_item_id")
  previousQuantity    Decimal    @default(0) @map("previous_quantity") @db.Decimal(12, 4)
  currentQuantity     Decimal    @default(0) @map("current_quantity") @db.Decimal(12, 4)
  accumulatedQuantity Decimal    @default(0) @map("accumulated_quantity") @db.Decimal(12, 4)
  unitPrice           Decimal    @default(0) @map("unit_price") @db.Decimal(14, 2)
  currentAmount       Decimal    @default(0) @map("current_amount") @db.Decimal(14, 2)
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  budgetItem  BudgetItem  @relation(fields: [budgetItemId], references: [id])

  @@unique([certificateId, budgetItemId])
  @@index([certificateId])
  @@map("certificate_items")
}

/// Registro de avance físico por partida
model ProgressEntry {
  id           String     @id @default(uuid())
  budgetItemId String     @map("budget_item_id")
  quantity     Decimal    @db.Decimal(12, 4)
  date         DateTime   @default(now())
  notes        String?
  recordedById String     @map("recorded_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  budgetItem   BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  recordedBy   User       @relation(fields: [recordedById], references: [id])

  @@index([budgetItemId, date(sort: Desc)])
  @@map("progress_entries")
}

/// Catálogo global de materiales
model Material {
  id        String           @id @default(uuid())
  name      String
  unit      MeasurementUnit
  unitPrice       Decimal          @default(0) @map("unit_price") @db.Decimal(14, 2)
  presentationQty Decimal          @default(1) @map("presentation_qty") @db.Decimal(12, 4)
  category        MaterialCategory @default(OTHER)
  brand     String?
  supplier  String?
  notes     String?
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  budgetItemMaterials BudgetItemMaterial[]

  @@index([category, isActive])
  @@index([name])
  @@map("materials")
}

/// Línea APU — material asignado a una partida
model BudgetItemMaterial {
  id                 String   @id @default(uuid())
  budgetItemId       String   @map("budget_item_id")
  materialId         String   @map("material_id")
  consumptionPerUnit Decimal  @map("consumption_per_unit") @db.Decimal(12, 4)
  wastePercent       Decimal  @default(0) @map("waste_percent") @db.Decimal(5, 2)
  unitCost           Decimal  @default(0) @map("unit_cost") @db.Decimal(14, 2)
  subtotal           Decimal  @default(0) @db.Decimal(14, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  material   Material   @relation(fields: [materialId], references: [id])

  @@unique([budgetItemId, materialId])
  @@index([budgetItemId])
  @@index([materialId])
  @@map("budget_item_materials")
}

/// Línea APU — mano de obra asignada a una partida
model BudgetItemLabor {
  id           String   @id @default(uuid())
  budgetItemId String   @map("budget_item_id")
  description  String
  costPerUnit  Decimal  @default(0) @map("cost_per_unit") @db.Decimal(14, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)

  @@index([budgetItemId])
  @@map("budget_item_labor")
}

/// Cobros del cliente (ingresos del proyecto)
model ClientPayment {
  id            String               @id @default(uuid())
  projectId     String               @map("project_id")
  amount        Decimal              @db.Decimal(14, 2)
  paymentDate   DateTime             @map("payment_date")
  paymentMethod PaymentMethod?       @map("payment_method")
  concept       ClientPaymentConcept @default(PROGRESS)
  reference     String?
  notes         String?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, paymentDate(sort: Desc)])
  @@index([projectId, concept])
  @@map("client_payments")
}

enum GlobalRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum ProjectRole {
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum MeasurementUnit {
  M2
  M3
  ML
  UNIT
  KG
  TON
  GLOBAL
}

enum CertificateStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AttachmentEntity {
  PROJECT
  BUDGET_ITEM
  CONTRACTOR
  PAYMENT
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_OVERDUE
  PROJECT_UPDATE
  ASSIGNMENT_CREATED
  GENERAL
}

enum ExpenseType {
  MATERIALS
  EQUIPMENT
  OVERHEAD
  PERMITS
  OTHER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  OTHER
}

enum MaterialCategory {
  CEMENT
  STEEL
  WOOD
  AGGREGATES
  CERAMICS
  PLUMBING
  ELECTRICAL
  PAINT
  WATERPROOFING
  HARDWARE
  OTHER
}

enum ClientPaymentConcept {
  ADVANCE
  PROGRESS
  FINAL
  RETENTION_RELEASE
  OTHER
}
