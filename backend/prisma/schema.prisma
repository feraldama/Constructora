// ============================================================================
// PRISMA SCHEMA — SaaS de Gestión de Obras de Construcción
// Base de datos: PostgreSQL
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum ProjectRole {
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum MeasurementUnit {
  M2
  M3
  ML
  UNIT
  KG
  TON
  GLOBAL
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AttachmentEntity {
  PROJECT
  BUDGET_ITEM
  CONTRACTOR
  PAYMENT
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_OVERDUE
  PROJECT_UPDATE
  ASSIGNMENT_CREATED
  GENERAL
}

// ============================================================================
// USUARIOS Y AUTENTICACIÓN
// ============================================================================

/// Usuarios del sistema
model User {
  id        String   @id @default(uuid())
  email     String   @unique // @unique ya crea índice, no necesita @@index adicional
  password  String
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  projectMembers ProjectMember[]
  notifications  Notification[]
  activityLogs   ActivityLog[]

  @@map("users")
}

// ============================================================================
// PROYECTOS
// ============================================================================

/// Proyectos de obra
model Project {
  id             String        @id @default(uuid())
  name           String
  description    String?
  address        String?
  initialBudget  Decimal       @default(0) @map("initial_budget") @db.Decimal(14, 2)
  status         ProjectStatus @default(PLANNING)
  startDate      DateTime?     @map("start_date")
  estimatedEnd   DateTime?     @map("estimated_end")
  actualEnd      DateTime?     @map("actual_end")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relaciones
  members        ProjectMember[]
  categories     Category[]
  contractors    ProjectContractor[]
  payments       Payment[]
  budgetSummary  BudgetSummary?
  attachments    Attachment[]
  activityLogs   ActivityLog[]

  // Dashboard: filtrar proyectos activos ordenados por fecha
  @@index([status, createdAt(sort: Desc)])
  @@map("projects")
}

/// Relación muchos-a-muchos entre usuarios y proyectos con rol
model ProjectMember {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  projectId String      @map("project_id")
  role      ProjectRole @default(VIEWER)
  joinedAt  DateTime    @default(now()) @map("joined_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  // Relaciones
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // @@unique ya crea índice sobre (userId, projectId)
  // Solo necesitamos índice inverso para "miembros de un proyecto"
  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_members")
}

// ============================================================================
// CÓMPUTO MÉTRICO — Categorías (Rubros) y Partidas (Items)
// ============================================================================

/// Categorías / Rubros del cómputo métrico
model Category {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetItems BudgetItem[]

  // Dashboard: listar rubros de un proyecto ordenados
  @@index([projectId, sortOrder])
  @@map("categories")
}

/// Partidas / Items del cómputo métrico
model BudgetItem {
  id          String          @id @default(uuid())
  categoryId  String          @map("category_id")
  name        String
  description String?
  unit        MeasurementUnit
  quantity    Decimal         @default(0) @db.Decimal(12, 4)
  unitPrice   Decimal         @default(0) @map("unit_price") @db.Decimal(14, 2)
  subtotal    Decimal         @default(0) @db.Decimal(14, 2)
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relaciones
  category    Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assignments ContractorAssignment[]
  payments    Payment[]
  attachments Attachment[]

  // Dashboard: listar partidas de un rubro ordenadas
  @@index([categoryId, sortOrder])
  @@map("budget_items")
}

// ============================================================================
// CONTRATISTAS
// ============================================================================

/// Contratistas
model Contractor {
  id          String   @id @default(uuid())
  name        String
  contactName String?  @map("contact_name")
  email       String?
  phone       String?
  taxId       String?  @unique @map("tax_id") // @unique ya crea índice
  address     String?
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  projects    ProjectContractor[]
  assignments ContractorAssignment[]
  payments    Payment[]
  attachments Attachment[]

  // Búsqueda por nombre activo
  @@index([isActive, name])
  @@map("contractors")
}

/// Relación contratista-proyecto
model ProjectContractor {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  contractorId String   @map("contractor_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relaciones
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  // @@unique cubre (projectId, contractorId), índice inverso para "proyectos de un contratista"
  @@unique([projectId, contractorId])
  @@index([contractorId])
  @@map("project_contractors")
}

/// Asignación de partidas a contratistas
model ContractorAssignment {
  id               String   @id @default(uuid())
  contractorId     String   @map("contractor_id")
  budgetItemId     String   @map("budget_item_id")
  assignedQuantity Decimal  @default(0) @map("assigned_quantity") @db.Decimal(12, 4)
  agreedPrice      Decimal  @default(0) @map("agreed_price") @db.Decimal(14, 2)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relaciones
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)

  // @@unique cubre (contractorId, budgetItemId), índice inverso para "contratistas de una partida"
  @@unique([contractorId, budgetItemId])
  @@index([budgetItemId])
  @@map("contractor_assignments")
}

// ============================================================================
// PAGOS
// ============================================================================

/// Pagos a contratistas
model Payment {
  id            String        @id @default(uuid())
  projectId     String        @map("project_id")
  contractorId  String        @map("contractor_id")
  budgetItemId  String?       @map("budget_item_id")
  amount        Decimal       @db.Decimal(14, 2)
  status        PaymentStatus @default(PENDING)
  description   String?
  invoiceNumber String?       @map("invoice_number")
  dueDate       DateTime?     @map("due_date")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relaciones
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractor  Contractor  @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  budgetItem  BudgetItem? @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  // Dashboard: "pagos pendientes/vencidos de un proyecto" — query más frecuente
  @@index([projectId, status])
  // Pagos: "historial de pagos a un contratista en un proyecto"
  @@index([projectId, contractorId])
  // Cron/alerta: detectar pagos vencidos (WHERE status IN (PENDING) AND due_date < NOW)
  @@index([status, dueDate])
  // Pagos: listado reciente por proyecto
  @@index([projectId, createdAt(sort: Desc)])
  @@map("payments")
}

// ============================================================================
// PRESUPUESTO — Resumen estimado vs real
// ============================================================================

/// Resumen de presupuesto por proyecto (tabla desnormalizada para dashboard rápido)
model BudgetSummary {
  id               String    @id @default(uuid())
  projectId        String    @unique @map("project_id") // 1:1, @unique ya es índice
  estimatedTotal   Decimal   @default(0) @map("estimated_total") @db.Decimal(14, 2)
  actualTotal      Decimal   @default(0) @map("actual_total") @db.Decimal(14, 2)
  totalPaid        Decimal   @default(0) @map("total_paid") @db.Decimal(14, 2)
  totalPending     Decimal   @default(0) @map("total_pending") @db.Decimal(14, 2)
  lastCalculatedAt DateTime? @map("last_calculated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relaciones
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("budget_summaries")
}

// ============================================================================
// ARCHIVOS ADJUNTOS (Polimórfico)
// ============================================================================

/// Archivos adjuntos relacionables a múltiples entidades
model Attachment {
  id           String           @id @default(uuid())
  fileName     String           @map("file_name")
  fileUrl      String           @map("file_url")
  fileSize     Int?             @map("file_size")
  mimeType     String?          @map("mime_type")
  entityType   AttachmentEntity @map("entity_type")

  // Foreign keys opcionales (polimorfismo con FKs tipadas)
  projectId    String?          @map("project_id")
  budgetItemId String?          @map("budget_item_id")
  contractorId String?          @map("contractor_id")
  paymentId    String?          @map("payment_id")

  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  // Relaciones
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetItem BudgetItem? @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  contractor Contractor? @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  payment    Payment?    @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  // Un solo índice compuesto: el entityType determina cuál FK tiene valor
  @@index([entityType, projectId])
  @@index([entityType, budgetItemId])
  @@index([entityType, contractorId])
  @@index([entityType, paymentId])
  @@map("attachments")
}

// ============================================================================
// NOTIFICACIONES
// ============================================================================

/// Notificaciones para usuarios
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dashboard: "notificaciones no leídas del usuario, más recientes primero"
  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================================================
// LOGS DE ACTIVIDAD — Auditoría
// ============================================================================

/// Registro de actividad para auditoría
model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  projectId  String?  @map("project_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relaciones
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Dashboard: "actividad reciente de un proyecto"
  @@index([projectId, createdAt(sort: Desc)])
  // Auditoría: buscar cambios de una entidad específica
  @@index([entityType, entityId])
  // Auditoría: actividad de un usuario
  @@index([userId, createdAt(sort: Desc)])
  @@map("activity_logs")
}
